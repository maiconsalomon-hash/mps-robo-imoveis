# Copie para .env e preencha com seus valores reais.
# Nunca commite o arquivo .env.

# --- Obrigatórias para sync com Supabase (sem as duas, o robô roda só SQLite/local) ---
SUPABASE_URL=https://xxxxxx.supabase.co
# Chave service_role do painel (Settings > API). Alternativa: SUPABASE_SERVICE_ROLE_KEY
SUPABASE_KEY=your-service-role-key-here

# --- Opcionais (Supabase) ---
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# SUPABASE_TABLE=properties
# SUPABASE_BATCH_SIZE=100

# --- Opcional (normalização com IA / Anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- MINI-ETAPA 7A — agendador (py scraper.py --scheduler) ---
# Requer SCHEDULE_ENABLED=true para iniciar o loop. Horários em HH:MM separados por vírgula.
# SCHEDULE_ENABLED=false
# SCHEDULE_TIMES=06:00,12:00,18:00
# SCHEDULE_TIMEZONE=America/Sao_Paulo
# SCHEDULE_MAX_CONSECUTIVE_FAILURES=3

# --- MINI-ETAPA 7B — retry por site na mesma rodada ---
# RETRY_ENABLED=true
# RETRY_MAX_SITES=5
# RETRY_DELAY_SECONDS=60
# RETRY_ERRORS_ELIGIBLE=ERRO_REQUISICAO,ERRO_RENDERIZACAO

# --- MINI-ETAPA 8A — filtro de qualidade no sync (Supabase) ---
# SYNC_FILTER_ENABLED=true
# SYNC_MIN_DATA_QUALITY_SCORE=40
# SYNC_BLOCK_LEGACY_IDENTITY=true

# --- MINI-ETAPA 8B — sync incremental inteligente (checkpoint em supabase_sync_state) ---
# SYNC_INCREMENTAL_ENABLED=true
# SYNC_FULL_RESYNC_INTERVAL_HOURS=24
# SYNC_INCREMENTAL_FULL_THRESHOLD_PCT=35
# Forçar sync completo na linha de comando: py scraper.py --full-sync

# --- API REST Domus (python api.py) ---
# Obrigatória em produção: sem ela, rotas com X-API-Key respondem 401.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
ROBOT_API_KEY=sua_chave_forte_aqui
# API_HOST=0.0.0.0
# API_PORT=8000
# Railway costuma definir PORT automaticamente; a api.py usa PORT se existir.

# --- Playwright (Chromium no container; use Dockerfile no Railway) ---
# PLAYWRIGHT_ENABLED=true
# PLAYWRIGHT_MAX_CONCURRENT=1
# PLAYWRIGHT_TIMEOUT=30000
